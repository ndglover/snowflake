// part: metadata

[setup]
drop = "TEST_ARRAY"

[tags]
sql-type-name = "ARRAY"

// part: setup_query

CREATE TABLE TEST_ARRAY (
    IDX INTEGER,
    RES ARRAY
);

INSERT INTO TEST_ARRAY VALUES (1, NULL);
INSERT INTO TEST_ARRAY
SELECT $1, PARSE_JSON($2)::ARRAY FROM VALUES
  (2, '[]'),
  (3, '[null]'),
  (4, '[1, 2, "hello world"]'),
  (5, '[[1, "hello world", NULL], 42.0, {"foobar": "foobar", "spam": 42}]');

// part: query

SELECT RES FROM TEST_ARRAY ORDER BY IDX

// part: expected_schema

{
    "format": "+s",
    "children": [
        {
            "name": "RES",
            "format": "u",
            "flags": ["nullable"],
            "metadata": {
                "ARROW:extension:name": "arrow.json"
            }
        }
    ]
}

// part: expected

{"RES": null}
{"RES": "[]"}
{"RES": "[\n  null\n]"}
{"RES": "[\n  1,\n  2,\n  \"hello world\"\n]"}
{"RES": "[\n  [\n    1,\n    \"hello world\",\n    null\n  ],\n  42,\n  {\n    \"foobar\": \"foobar\",\n    \"spam\": 42\n  }\n]"}
