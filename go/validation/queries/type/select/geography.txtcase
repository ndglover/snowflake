// part: metadata

[setup]
drop = "TEST_GEOGRAPHY"

[tags]
field-type-name = "GEOGRAPHY"
sql-type-name = "GEOGRAPHY (geography_output_format = GEOJSON)"

// part: setup_query

CREATE TABLE TEST_GEOGRAPHY (
    IDX INTEGER,
    RES GEOGRAPHY
);

INSERT INTO TEST_GEOGRAPHY VALUES (1, NULL),
  (2, 'GEOMETRYCOLLECTION EMPTY'),
  (3, 'POINT(1 2)'),
  (4, 'LINESTRING(1 2, 3 4)'),
  (5, 'POLYGON((0 0, 1 0, 1 1, 0 1, 0 0))'),
  (6, 'MULTIPOINT(1 2, 3 4)'),
  (7, 'MULTILINESTRING((1 2, 3 4), (5 6, 7 8))'),
  (8, 'MULTIPOLYGON(((0 0, 1 0, 1 1, 0 1, 0 0)), ((0 0, -1 0, -1 -1, 0 -1, 0 0)))'),
  (9, 'GEOMETRYCOLLECTION(POINT(1 2), LINESTRING(3 4, 5 6))')
;

// part: query

SELECT RES FROM TEST_GEOGRAPHY ORDER BY IDX ASC

// part: expected_schema

{
    "format": "+s",
    "children": [
        {
            "name": "RES",
            "format": "u",
            "flags": ["nullable"]
        }
    ]
}

// part: expected

{"RES": null}
{"RES": null}
{"RES": "{\n  \"coordinates\": [\n    1,\n    2\n  ],\n  \"type\": \"Point\"\n}"}
{"RES": "{\n  \"coordinates\": [\n    [\n      1,\n      2\n    ],\n    [\n      3,\n      4\n    ]\n  ],\n  \"type\": \"LineString\"\n}"}
{"RES": "{\n  \"coordinates\": [\n    [\n      [\n        0,\n        0\n      ],\n      [\n        1,\n        0\n      ],\n      [\n        1,\n        1\n      ],\n      [\n        0,\n        1\n      ],\n      [\n        0,\n        0\n      ]\n    ]\n  ],\n  \"type\": \"Polygon\"\n}"}
{"RES": "{\n  \"coordinates\": [\n    [\n      1,\n      2\n    ],\n    [\n      3,\n      4\n    ]\n  ],\n  \"type\": \"MultiPoint\"\n}"}
{"RES": "{\n  \"coordinates\": [\n    [\n      [\n        1,\n        2\n      ],\n      [\n        3,\n        4\n      ]\n    ],\n    [\n      [\n        5,\n        6\n      ],\n      [\n        7,\n        8\n      ]\n    ]\n  ],\n  \"type\": \"MultiLineString\"\n}"}
{"RES": "{\n  \"coordinates\": [\n    [\n      [\n        [\n          0,\n          0\n        ],\n        [\n          1,\n          0\n        ],\n        [\n          1,\n          1\n        ],\n        [\n          0,\n          1\n        ],\n        [\n          0,\n          0\n        ]\n      ]\n    ],\n    [\n      [\n        [\n          0,\n          0\n        ],\n        [\n          -1,\n          0\n        ],\n        [\n          -1,\n          -1\n        ],\n        [\n          0,\n          -1\n        ],\n        [\n          0,\n          0\n        ]\n      ]\n    ]\n  ],\n  \"type\": \"MultiPolygon\"\n}"}
{"RES": "{\n  \"geometries\": [\n    {\n      \"coordinates\": [\n        1,\n        2\n      ],\n      \"type\": \"Point\"\n    },\n    {\n      \"coordinates\": [\n        [\n          3,\n          4\n        ],\n        [\n          5,\n          6\n        ]\n      ],\n      \"type\": \"LineString\"\n    }\n  ],\n  \"type\": \"GeometryCollection\"\n}"}
