{"RES": "AQMAAAABAAAABQAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAADwPwAAAAAAAAAAAAAAAAAA8D8AAAAAAADwPwAAAAAAAAAAAAAAAAAA8D8AAAAAAAAAAAAAAAAAAAAA"}
{"RES": "AQQAAAACAAAAAQEAAAAAAAAAAADwPwAAAAAAAABAAQEAAAAAAAAAAAAIQAAAAAAAABBA"}
{"RES": "AQUAAAACAAAAAQIAAAACAAAAAAAAAAAA8D8AAAAAAAAAQAAAAAAAAAhAAAAAAAAAEEABAgAAAAIAAAAAAAAAAAAUQAAAAAAAABhAAAAAAAAAHEAAAAAAAAAgQA=="}
{"RES": "AQYAAAACAAAAAQMAAAABAAAABQAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAADwPwAAAAAAAAAAAAAAAAAA8D8AAAAAAADwPwAAAAAAAAAAAAAAAAAA8D8AAAAAAAAAAAAAAAAAAAAAAQMAAAABAAAABQAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAADwvwAAAAAAAAAAAAAAAAAA8L8AAAAAAADwvwAAAAAAAAAAAAAAAAAA8L8AAAAAAAAAAAAAAAAAAAAA"}
{"RES": "AQcAAAACAAAAAQEAAAAAAAAAAADwPwAAAAAAAABAAQIAAAACAAAAAAAAAAAACEAAAAAAAAAQQAAAAAAAABRAAAAAAAAAGEA="}
